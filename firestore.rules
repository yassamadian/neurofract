rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Patients can read/write their own patient document
    // Clinicians can read patients assigned to them
    match /patients/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinician' &&
        resource.data.clinicianId == request.auth.uid;
    }

    // Assessments: patients write their own, clinicians read their patients'
    // Researchers read anonymised fields only (enforced in app logic)
    match /assessments/{assessmentId} {
      allow create: if request.auth != null && request.resource.data.patientId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinician' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'researcher'
      );
      // No updates or deletes — data integrity for research
      allow update, delete: if false;
    }

    // Seizures: same rules as assessments
    match /seizures/{seizureId} {
      allow create: if request.auth != null && request.resource.data.patientId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinician' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'researcher'
      );
      allow update, delete: if false;
    }

    // Alerts: clinicians create and read, patients read their own
    match /alerts/{alertId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        resource.data.clinicianId == request.auth.uid
      );
      allow create, update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinician';
      allow delete: if false;
    }

    // Messages: patients and clinicians can read/write messages they are party to
    // - Patient can read/write messages where patientId == their uid
    // - Clinician can read/write messages where clinicianId == their uid OR
    //   messages from their patients (sender=patient, patientId in their list)
    // - update allowed only to mark read=true (no editing message text enforced in app)
    // - no deletes
    match /messages/{messageId} {
      allow read: if request.auth != null && (
        resource.data.patientId  == request.auth.uid ||
        resource.data.clinicianId == request.auth.uid
      );
      allow create: if request.auth != null && (
        // Patient sending: patientId must be their own uid, sender must be 'patient'
        (request.resource.data.patientId == request.auth.uid &&
         request.resource.data.sender == 'patient') ||
        // Clinician sending: sender must be 'clinician'
        (request.resource.data.sender == 'clinician' &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinician')
      );
      allow update: if request.auth != null && (
        resource.data.patientId  == request.auth.uid ||
        resource.data.clinicianId == request.auth.uid
      );
      allow delete: if false;
    }
  }
}
